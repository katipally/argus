# Argus — optional API keys.
# Copy this file to `.env.local` and fill in only what you want. Core layers
# work keyless. Free keys unlock: fresher wildfires, ships, wider street
# imagery, global webcams, and the AI agent.
# Restart the dev server after editing. Status: in-app Settings → Status.
# NOTE: an empty `NAME=` line counts as NO key — paste a real value.

# ── Wildfires freshness upgrade (NASA FIRMS) ─────────────────────────────────
# Keyless fallback (global 24h VIIRS CSV) is always active. A free instant key
# switches to the bbox-scoped near-real-time API:
# https://firms.modaps.eosdis.nasa.gov/api/map_key
FIRMS_MAP_KEY=

# ── Street imagery: Mapillary (optional wider coverage) ──────────────────────
# Panoramax street view is always on and keyless. A free Mapillary client token
# adds a second, far larger global coverage network (shown in blue). Client
# token is safe to expose (read-only, per-app rate-limited):
# https://www.mapillary.com/dashboard/developers
NEXT_PUBLIC_MAPILLARY_TOKEN=

# ── Global webcams (Windy) ───────────────────────────────────────────────────
# The Webcams layer always shows curated famous 24/7 YouTube Lives keyless. A
# free Windy key adds their worldwide webcam network (previews + player embeds).
# Server-side only: https://api.windy.com/webcams
WINDY_API_KEY=

# ── Maritime AIS ships (AISStream) ───────────────────────────────────────────
# Adds the live Ships layer. Free key (GitHub sign-in). Argus proxies the AIS
# WebSocket server-side as SSE (browsers can't reach it directly), so the key is
# only read server-side despite the NEXT_PUBLIC_ name:
# https://aisstream.io
NEXT_PUBLIC_AISSTREAM_KEY=

# ── Argus Agent (LLM) ────────────────────────────────────────────────────────
# Server-side only. Pick the provider(s) you have — configure provider/model/
# effort in-app under Settings → AI (model lists load live from the provider).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
